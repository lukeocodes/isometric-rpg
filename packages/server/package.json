    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "postgres": "^3.4.0",
    "simplex-noise": "^4.0.3",
    "tsx": "^4.21.0",
    "werift": "^0.22.9"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@vitest/coverage-v8": "^4.1.0",
